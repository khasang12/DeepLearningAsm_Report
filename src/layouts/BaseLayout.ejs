<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || 'Deep Learning Assignments' %> - HK252</title>
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.8.1/font/bootstrap-icons.css">
    
    <!-- Tailwind CSS -->
    <link rel="stylesheet" href="styles.css">
    
    <!-- Favicon (optional) -->
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🧠</text></svg>">
    
    <!-- Additional meta tags -->
    <meta name="description" content="<%= site.description || 'GitHub Pages for Deep Learning course assignments' %>">
    <meta name="keywords" content="deep learning, machine learning, HK252, assignment, CNN, neural networks">
    <meta name="author" content="<%= group.name || 'Student Group' %>">
    
    <!-- Open Graph tags for social sharing -->
    <meta property="og:title" content="<%= title || 'Deep Learning Assignments' %>">
    <meta property="og:description" content="<%= site.description || 'GitHub Pages for Deep Learning course assignments' %>">
    <meta property="og:type" content="website">
    
    <style>
        /* Critical CSS for above-the-fold content */
        .page-loading {
            opacity: 0;
            transition: opacity 0.3s ease-in;
        }
        .page-loaded {
            opacity: 1;
        }
    </style>
</head>
<body class="min-h-screen bg-gray-50 text-gray-900 font-sans antialiased page-loading">
    
    <% if (typeof content === 'function') { %>
        <%= content() %>
    <% } else if (content) { %>
        <%= content %>
    <% } %>
    
    <!-- Bootstrap Icons are loaded via CDN -->
    <!-- No additional JavaScript needed for basic functionality -->
    
    <script>
        // Simple page load animation
        document.addEventListener('DOMContentLoaded', () => {
            document.body.classList.add('page-loaded');
        });
        
        // Service Worker registration (optional enhancement)
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                navigator.serviceWorker.register('/sw.js').catch(() => {});
            });
        }
    </script>
</body>
</html>