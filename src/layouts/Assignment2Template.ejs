<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<%- component('organisms/Head/Head', {
    title: 'Assignment 2 - ' + (assignment.selectedTopic || assignment.title),
    description: site.description,
    author: group.name,
    group: group
}) -%>
<body class="min-h-screen bg-gray-50 text-gray-900 font-sans antialiased page-loading dark:bg-gray-900 dark:text-gray-100">
    
    <!-- Header -->
    <%- component('organisms/Header/Header', {
        title: 'Assignment ' + assignment.number,
        subtitle: assignment.subtitle,
        gradient: assignment.gradient,
        showHomeButton: true,
        showAssignmentInfo: true,
        assignmentNumber: assignment.number,
        themeColor: assignment.themeColor,
        badgeText: assignment.selectedTopic,
        group: group,
        instructor: instructor
    }) -%>
    
    <!-- Main Content -->
    <main class="container mx-auto px-4 py-8 md:py-12">
        <div class="max-w-7xl mx-auto space-y-10">
        <%
        // Color palette map — fixes Tailwind JIT purging of dynamic classes
        var colorMap = {
          'primary': { bg100:'#dbeafe', bg50:'#eff6ff', border:'#bfdbfe', text600:'#2563eb', text700:'#1d4ed8', text800:'#1e40af' },
          'success':  { bg100:'#dcfce7', bg50:'#f0fdf4', border:'#bbf7d0', text600:'#16a34a', text700:'#15803d', text800:'#166534' },
          'warning':  { bg100:'#fef9c3', bg50:'#fefce8', border:'#fde68a', text600:'#ca8a04', text700:'#a16207', text800:'#854d0e' },
          'info':     { bg100:'#cffafe', bg50:'#ecfeff', border:'#a5f3fc', text600:'#0891b2', text700:'#0e7490', text800:'#155e75' },
          'danger':   { bg100:'#fee2e2', bg50:'#fef2f2', border:'#fecaca', text600:'#dc2626', text700:'#b91c1c', text800:'#991b1b' },
          'red':      { bg100:'#fee2e2', bg50:'#fef2f2', border:'#fecaca', text600:'#dc2626', text700:'#b91c1c', text800:'#991b1b' }
        };
        function cm(color) { return colorMap[color] || colorMap['primary']; }
        %>
            <!-- ═══════════════════════════════════════════════════════════ -->
            <!-- Deliverables Section                                       -->
            <!-- ═══════════════════════════════════════════════════════════ -->
            <section class="card">
                <div class="flex items-center mb-6">
                    <i class="bi bi-box-seam-fill text-2xl text-primary-600 mr-3"></i>
                    <h2 class="text-2xl font-bold text-gray-900">Deliverables</h2>
                </div>
                
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    <!-- Demo Video -->
                    <div class="flex items-center p-4 border border-gray-200 rounded-xl hover:border-primary-300 transition-colors">
                        <i class="bi bi-play-btn-fill text-3xl text-red-500 mr-4"></i>
                        <div>
                            <h3 class="font-semibold text-gray-900 mb-1"><%= deliverables.demoVideo.label %></h3>
                            <p class="text-sm text-gray-600 mb-3"><%= deliverables.demoVideo.description %></p>
                            <a href="<%= deliverableLinks.demoVideo %>" 
                               class="btn-outline text-sm py-1.5 px-3 border-red-300 text-red-600 hover:bg-red-50"
                               target="_blank" rel="noopener noreferrer">
                                Watch Video
                            </a>
                        </div>
                    </div>
                    
                    <!-- Presentation Video -->
                    <div class="flex items-center p-4 border border-gray-200 rounded-xl hover:border-primary-300 transition-colors">
                        <i class="bi bi-youtube text-3xl text-red-500 mr-4"></i>
                        <div>
                            <h3 class="font-semibold text-gray-900 mb-1"><%= deliverables.presentationVideo.label %></h3>
                            <p class="text-sm text-gray-600 mb-3"><%= deliverables.presentationVideo.description %></p>
                            <a href="<%= deliverableLinks.presentationVideo %>" 
                               class="btn-outline text-sm py-1.5 px-3 border-red-300 text-red-600 hover:bg-red-50"
                               target="_blank" rel="noopener noreferrer">
                                Watch on YouTube
                            </a>
                        </div>
                    </div>
                    
                    <!-- Source Code -->
                    <div class="flex items-center p-4 border border-gray-200 rounded-xl hover:border-primary-300 transition-colors">
                        <i class="bi bi-github text-3xl text-gray-700 mr-4"></i>
                        <div>
                            <h3 class="font-semibold text-gray-900 mb-1"><%= deliverables.sourceCode.label %></h3>
                            <p class="text-sm text-gray-600 mb-3"><%= deliverables.sourceCode.description %></p>
                            <a href="<%= deliverableLinks.sourceCode %>" 
                               class="btn-outline text-sm py-1.5 px-3 border-gray-300 text-gray-700 hover:bg-gray-50"
                               target="_blank" rel="noopener noreferrer">
                                View Code
                            </a>
                        </div>
                    </div>
                </div>
            </section>

            <!-- ═══════════════════════════════════════════════════════════ -->
            <!-- REPORT 1 — EDA: Problem Statement & Dataset                 -->
            <!-- ═══════════════════════════════════════════════════════════ -->
            <section id="section-eda" class="card scroll-mt-20">
                <div class="flex items-center mb-2">
                    <span class="badge-primary mr-3 text-base px-3 py-1">Report 1</span>
                    <h2 class="text-2xl font-bold text-gray-900">EDA — Problem Statement & ADE20K Dataset</h2>
                </div>
                <p class="text-gray-500 text-sm mb-8 ml-1">Exploring the Semantic Segmentation task and a detailed analysis of the ADE20K dataset</p>

                <!-- Problem Statement + Dataset Stats -->
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
                    <!-- Problem Statement -->
                    <div class="bg-gradient-to-br from-primary-50 to-blue-50 rounded-2xl p-6 border border-primary-100">
                        <div class="flex items-center mb-4">
                            <i class="bi bi-bullseye text-2xl text-primary-600 mr-3"></i>
                            <h3 class="text-lg font-bold text-gray-900">Task: Semantic Segmentation</h3>
                        </div>
                        <p class="text-gray-700 text-sm mb-4 leading-relaxed">
                            Semantic segmentation assigns a class label to <strong>every pixel</strong> in an image — unlike object detection (bounding boxes only) or image classification (single label per image). It is a fundamental task for autonomous driving, medical imaging, and scene understanding.
                        </p>
                        <div class="space-y-2">
                            <div class="flex items-center text-sm">
                                <i class="bi bi-check-circle-fill text-primary-500 mr-2"></i>
                                <span class="text-gray-700">Input: RGB image \(\mathbf{I} \in \mathbb{R}^{H \times W \times 3}\)</span>
                            </div>
                            <div class="flex items-center text-sm">
                                <i class="bi bi-check-circle-fill text-primary-500 mr-2"></i>
                                <span class="text-gray-700">Output: Pixel-wise label map \(\mathbf{Y} \in \{0,\dots,149\}^{H \times W}\)</span>
                            </div>
                            <div class="flex items-center text-sm">
                                <i class="bi bi-check-circle-fill text-primary-500 mr-2"></i>
                                <span class="text-gray-700">Primary metric: mIoU \(= \frac{1}{C}\sum_c \frac{|P_c \cap G_c|}{|P_c \cup G_c|}\)</span>
                            </div>
                            <div class="flex items-center text-sm">
                                <i class="bi bi-check-circle-fill text-primary-500 mr-2"></i>
                                <span class="text-gray-700">Key challenges: extreme class imbalance, fine boundary prediction</span>
                            </div>
                        </div>
                    </div>

                    <!-- Dataset Stats -->
                    <div class="bg-gradient-to-br from-green-50 to-emerald-50 rounded-2xl p-6 border border-green-100">
                        <div class="flex items-center mb-4">
                            <i class="bi bi-database-fill text-2xl text-green-600 mr-3"></i>
                            <h3 class="text-lg font-bold text-gray-900">ADE20K Dataset Statistics</h3>
                        </div>
                        <div class="grid grid-cols-2 gap-3">
                            <div class="bg-white rounded-xl p-3 text-center shadow-sm border border-green-100">
                                <div class="text-2xl font-bold text-green-600"><%= dataset.numClasses %></div>
                                <div class="text-xs text-gray-500 mt-1">Semantic Classes</div>
                                <span class="mt-2 inline-block bg-green-100 text-green-700 text-xs font-semibold px-2 py-0.5 rounded-full">Scene Parsing</span>
                            </div>
                            <div class="bg-white rounded-xl p-3 text-center shadow-sm border border-blue-100">
                                <div class="text-2xl font-bold text-blue-600"><%= dataset.trainSize.toLocaleString() %></div>
                                <div class="text-xs text-gray-500 mt-1">Training Images</div>
                                <span class="mt-2 inline-block bg-blue-100 text-blue-700 text-xs font-semibold px-2 py-0.5 rounded-full">Train Split</span>
                            </div>
                            <div class="bg-white rounded-xl p-3 text-center shadow-sm border border-purple-100">
                                <div class="text-2xl font-bold text-purple-600"><%= dataset.valSize.toLocaleString() %></div>
                                <div class="text-xs text-gray-500 mt-1">Validation Images</div>
                                <span class="mt-2 inline-block bg-purple-100 text-purple-700 text-xs font-semibold px-2 py-0.5 rounded-full">Val Split</span>
                            </div>
                            <div class="bg-white rounded-xl p-3 text-center shadow-sm border border-red-100">
                                <div class="text-2xl font-bold text-red-600"><%= dataset.imbalanceRatio %></div>
                                <div class="text-xs text-gray-500 mt-1">Imbalance Ratio</div>
                                <span class="mt-2 inline-block bg-red-100 text-red-700 text-xs font-semibold px-2 py-0.5 rounded-full">Long-tail</span>
                            </div>
                        </div>
                        <p class="text-xs text-gray-500 mt-3">Source: <%= dataset.source %></p>
                    </div>
                </div>

                <!-- Class Imbalance Key Insight -->
                <div class="bg-amber-50 border border-amber-200 rounded-2xl p-5 mb-8">
                    <div class="flex items-start">
                        <i class="bi bi-exclamation-triangle-fill text-amber-500 text-xl mr-3 mt-0.5"></i>
                        <div>
                            <p class="font-bold text-amber-800 mb-1">Key EDA Insight — Extreme Class Imbalance</p>
                            <p class="text-amber-700 text-sm leading-relaxed"><%= dataset.keyFact %></p>
                            <div class="mt-3 flex flex-wrap gap-2">
                                <span class="text-xs font-semibold">Dominant:</span>
                                <% dataset.dominantClasses.forEach(function(c) { -%>
                                <span class="bg-amber-200 text-amber-800 text-xs px-2 py-0.5 rounded-full"><%= c %></span>
                                <% }) -%>
                                <span class="text-xs font-semibold ml-2">Rare:</span>
                                <% dataset.rareClasses.forEach(function(c) { -%>
                                <span class="bg-red-100 text-red-700 text-xs px-2 py-0.5 rounded-full"><%= c %></span>
                                <% }) -%>
                            </div>
                            <p class="text-amber-700 text-sm mt-2 font-medium">→ Justifies using <strong>Focal Loss + Dice Loss</strong> and <strong>Copy-Paste augmentation</strong> to handle rare classes.</p>
                        </div>
                    </div>
                </div>

                <!-- Architecture Theory Table -->
                <!-- EDA Image -->
                <div class="mb-8 rounded-2xl overflow-hidden border border-gray-200 shadow-sm">
                    <img src="assets/asm2_class_frequency_distribution.png" alt="Class Frequency Distribution (ADE20K)" class="w-full h-auto" loading="lazy">
                    <p class="text-center text-gray-500 text-sm py-3 bg-gray-50 font-medium">Figure 1 — Class Frequency Distribution (ADE20K)</p>
                </div>

                <h3 class="text-lg font-bold text-gray-900 mb-4 flex items-center">
                    <i class="bi bi-table text-primary-600 mr-2"></i>
                    Architecture Comparison: SegFormer vs. DeepLabV3+
                </h3>
                <div class="overflow-x-auto rounded-xl border border-gray-200 mb-4">
                    <table class="min-w-full divide-y divide-gray-200 text-sm">
                        <thead class="bg-primary-50">
                            <tr>
                                <th class="px-5 py-3 text-left text-xs font-semibold text-primary-700 uppercase">Aspect</th>
                                <th class="px-5 py-3 text-left text-xs font-semibold text-primary-700 uppercase">SegFormer (Transformer)</th>
                                <th class="px-5 py-3 text-left text-xs font-semibold text-primary-700 uppercase">DeepLabV3+ (CNN)</th>
                            </tr>
                        </thead>
                        <tbody class="bg-white divide-y divide-gray-100">
                            <tr class="hover:bg-gray-50"><td class="px-5 py-3 font-medium text-gray-700">Encoder</td><td class="px-5 py-3 text-gray-600">Mix Transformer (MiT) — hierarchical ViT</td><td class="px-5 py-3 text-gray-600">ResNet-101 / ConvNeXt-Base — deep CNNs</td></tr>
                            <tr class="hover:bg-gray-50 bg-gray-50"><td class="px-5 py-3 font-medium text-gray-700">Decoder</td><td class="px-5 py-3 text-gray-600">Lightweight All-MLP Head</td><td class="px-5 py-3 text-gray-600">ASPP + Encoder-Decoder with Skip Connections</td></tr>
                            <tr class="hover:bg-gray-50"><td class="px-5 py-3 font-medium text-gray-700">Positional Encoding</td><td class="px-5 py-3 text-gray-600">Not needed — Mix-FFN with 3×3 conv</td><td class="px-5 py-3 text-gray-600">N/A (implicit in convolutions)</td></tr>
                            <tr class="hover:bg-gray-50 bg-gray-50"><td class="px-5 py-3 font-medium text-gray-700">Multi-scale</td><td class="px-5 py-3 text-gray-600">4-stage hierarchical feature maps</td><td class="px-5 py-3 text-gray-600">Atrous Spatial Pyramid Pooling (ASPP)</td></tr>
                            <tr class="hover:bg-gray-50"><td class="px-5 py-3 font-medium text-gray-700">Receptive Field</td><td class="px-5 py-3 text-gray-600">Global (full-image self-attention)</td><td class="px-5 py-3 text-gray-600">Local → Global (dilated convolutions)</td></tr>
                            <tr class="hover:bg-gray-50 bg-gray-50"><td class="px-5 py-3 font-medium text-gray-700">Parameters</td><td class="px-5 py-3 font-semibold text-green-600">27.5M (B2) — Lightest</td><td class="px-5 py-3 text-gray-600">45.7M (ResNet-101), 89.4M (ConvNeXt-B)</td></tr>
                            <tr class="hover:bg-gray-50"><td class="px-5 py-3 font-medium text-gray-700">ADE20K mIoU</td><td class="px-5 py-3 text-gray-600">46.27 (B2)</td><td class="px-5 py-3 text-gray-600">39.20 (ResNet-101), 47.94 (ConvNeXt-B)</td></tr>
                        </tbody>
                    </table>
                </div>
            </section>

            <!-- ═══════════════════════════════════════════════════════════ -->
            <!-- REPORT 2 — Dataset, DataLoader & Augmentation             -->
            <!-- ═══════════════════════════════════════════════════════════ -->
            <section id="section-data" class="card scroll-mt-20">
                <div class="flex items-center mb-2">
                    <span class="badge-success mr-3 text-base px-3 py-1">Report 2</span>
                    <h2 class="text-2xl font-bold text-gray-900">Dataset, DataLoader &amp; Augmentation Pipeline</h2>
                </div>
                <p class="text-gray-500 text-sm mb-8 ml-1">Data preparation and augmentation strategies to address extreme class imbalance in ADE20K</p>

                <!-- Dataset wrapper highlight -->
                <div class="bg-gray-900 rounded-2xl p-5 mb-8 font-mono text-sm">
                    <div class="flex items-center mb-3">
                        <div class="w-3 h-3 rounded-full bg-red-400 mr-2"></div>
                        <div class="w-3 h-3 rounded-full bg-yellow-400 mr-2"></div>
                        <div class="w-3 h-3 rounded-full bg-green-400 mr-2"></div>
                        <span class="text-gray-400 text-xs ml-2">ADE20KFileDataset — Label Remapping</span>
                    </div>
                    <pre class="text-green-400 leading-relaxed overflow-x-auto"><code><span class="text-yellow-300">class</span> <span class="text-blue-300">ADE20KFileDataset</span>:
    <span class="text-gray-400"># Remaps class indices → 0–149 (150 classes)</span>
    <span class="text-gray-400"># Void/unlabeled pixels → 255 (ignore_index)</span>
    <span class="text-yellow-300">def</span> <span class="text-blue-300">__getitem__</span>(self, idx):
        image = <span class="text-orange-300">load_image</span>(self.image_paths[idx])
        mask  = <span class="text-orange-300">remap_labels</span>(self.mask_paths[idx])
        <span class="text-yellow-300">return</span> {<span class="text-green-300">"image"</span>: image, <span class="text-green-300">"annotation"</span>: mask}</code></pre>
                </div>

                <!-- Augmentation Pipeline -->
                <h3 class="text-lg font-bold text-gray-900 mb-5 flex items-center">
                    <i class="bi bi-arrow-right-circle-fill text-success-600 mr-2 text-green-600"></i>
                    Augmentation Pipeline
                </h3>
                <div class="relative mb-8">
                    <!-- Connecting line -->
                    <div class="hidden md:block absolute top-10 left-0 right-0 h-0.5 bg-gradient-to-r from-primary-200 via-green-200 to-red-200 z-0 mx-16"></div>
                    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-5 gap-4 relative z-10">
                        <% augmentations.forEach(function(aug, i) { var ac = cm(aug.color !== 'danger' ? aug.color : 'red'); -%>
                        <div class="bg-white rounded-2xl border border-gray-200 p-4 shadow-sm hover:shadow-md transition-all hover:-translate-y-1 text-center flex flex-col items-center">
                            <div class="w-12 h-12 rounded-full flex items-center justify-center mx-auto mb-3" style="background-color:<%= ac.bg100 %>">
                                <i class="bi <%= aug.icon %> text-xl" style="color:<%= ac.text600 %>"></i>
                            </div>
                            <p class="font-semibold text-gray-900 text-xs mb-1"><%= aug.name %></p>
                            <span class="inline-block text-xs font-semibold px-2 py-0.5 rounded-full mb-2" style="background-color:<%= ac.bg100 %>;color:<%= ac.text700 %>"><%= aug.type || 'Geometric' %></span>
                            <p class="text-gray-500 text-xs leading-relaxed"><%= aug.description %></p>
                        </div>
                        <% }) %>
                    </div>
                </div>

                <!-- DataLoader Config -->
                <div class="bg-blue-50 border border-blue-100 rounded-xl p-4">
                    <div class="flex items-center mb-2">
                        <i class="bi bi-info-circle-fill text-blue-500 mr-2"></i>
                        <span class="font-semibold text-blue-800 text-sm">DataLoader Configuration</span>
                    </div>
                    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mt-3">
                        <div class="text-center"><p class="text-xs text-blue-600 font-mono font-bold">pin_memory=True</p><p class="text-xs text-blue-500">Zero-copy GPU transfer</p></div>
                        <div class="text-center"><p class="text-xs text-blue-600 font-mono font-bold">num_workers=4+</p><p class="text-xs text-blue-500">Multi-process loading</p></div>
                        <div class="text-center"><p class="text-xs text-blue-600 font-mono font-bold">512×512 crop</p><p class="text-xs text-blue-500">Unified resolution</p></div>
                        <div class="text-center"><p class="text-xs text-blue-600 font-mono font-bold">ignore_index=255</p><p class="text-xs text-blue-500">Void pixel masking</p></div>
                    </div>
                </div>

                <!-- Augmentation Visual -->
                <div class="mt-8 rounded-2xl overflow-hidden border border-gray-200 shadow-sm">
                    <img src="assets/asm2_augmented_training_samples.png" alt="Augmented Sample Visualizations" class="w-full h-auto" loading="lazy">
                    <p class="text-center text-gray-500 text-sm py-3 bg-gray-50 font-medium">Figure 2 — Augmented Sample Visualizations</p>
                </div>
            </section>

            <!-- ═══════════════════════════════════════════════════════════ -->
            <!-- REPORT 3 — Model Architectures, Training, Evaluation      -->
            <!-- ═══════════════════════════════════════════════════════════ -->
            <section id="section-methods" class="card scroll-mt-20">
                <div class="flex items-center mb-2">
                    <span class="badge-info mr-3 text-base px-3 py-1">Report 3</span>
                    <h2 class="text-2xl font-bold text-gray-900">Methodology: Architecture, Training &amp; Evaluation</h2>
                </div>
                <p class="text-gray-500 text-sm mb-8 ml-1">Design, training, and comparison of 3 segmentation methods on ADE20K</p>

                <!-- Architecture Cards -->
                <h3 class="text-base font-bold text-gray-800 mb-4 flex items-center">
                    <i class="bi bi-diagram-3-fill text-info-600 mr-2 text-blue-500"></i>
                    Model Architectures (3 Methods)
                </h3>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-8">
                    <% architectures.forEach(function(arch) { var ac = cm(arch.color); -%>
                    <div class="rounded-2xl border-2 p-5 relative overflow-hidden bg-white hover:shadow-lg transition-shadow"
                         style="border-color:<%= arch.highlight ? '#facc15' : ac.border %>">
                        <% if (arch.highlight) { -%>
                        <div class="absolute top-3 right-3 bg-yellow-400 text-yellow-900 text-xs font-bold px-2 py-0.5 rounded-full">Best mIoU ★</div>
                        <% } -%>
                        <div class="flex items-center mb-4">
                            <div class="w-10 h-10 rounded-xl flex items-center justify-center mr-3" style="background-color:<%= ac.bg100 %>">
                                <i class="bi <%= arch.icon %> text-lg" style="color:<%= ac.text600 %>"></i>
                            </div>
                            <div>
                                <h4 class="font-bold text-gray-900 text-sm"><%= arch.name %></h4>
                                <span class="text-xs px-2 py-0.5 rounded-full" style="background-color:<%= ac.bg100 %>;color:<%= ac.text700 %>"><%= arch.tag %></span>
                            </div>
                        </div>
                        <p class="text-xs text-gray-600 mb-4 leading-relaxed"><%= arch.description %></p>
                        <div class="space-y-1.5 mb-4">
                            <div class="flex justify-between text-xs"><span class="text-gray-500">Backbone</span><span class="font-medium text-gray-800"><%= arch.backbone %></span></div>
                            <div class="flex justify-between text-xs"><span class="text-gray-500">Decoder</span><span class="font-medium text-gray-800"><%= arch.decoder %></span></div>
                            <div class="flex justify-between text-xs"><span class="text-gray-500">Parameters</span><span class="font-bold" style="color:<%= ac.text600 %>"><%= arch.params %></span></div>
                            <div class="flex justify-between text-xs"><span class="text-gray-500">ADE20K mIoU</span><span class="font-bold" style="color:<%= ac.text600 %>"><%= arch.miou %>%</span></div>
                        </div>
                        <div class="border-t border-gray-100 pt-3">
                            <p class="text-xs text-gray-500 font-semibold mb-1.5">Strengths</p>
                            <% arch.strengths.forEach(function(s) { -%>
                            <div class="flex items-start text-xs text-gray-600 mb-1">
                                <i class="bi bi-check2 text-green-500 mr-1.5 mt-0.5 flex-shrink-0"></i>
                                <span><%= s %></span>
                            </div>
                            <% }) -%>
                        </div>
                    </div>
                    <% }) %>
                </div>

                <!-- Loss Functions -->
                <h3 class="text-base font-bold text-gray-800 mb-4 flex items-center">
                    <i class="bi bi-calculator-fill text-purple-500 mr-2"></i>
                    Hybrid Loss Function: Focal + Dice + Boundary + Lovász
                </h3>
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
                    <% lossFunctions.forEach(function(loss) { var lc = cm(loss.color); -%>
                    <div class="rounded-xl p-4 border" style="background-color:<%= lc.bg50 %>;border-color:<%= lc.border %>">
                        <h4 class="font-bold text-sm mb-1" style="color:<%= lc.text800 %>"><%= loss.name %></h4>
                        <div class="text-sm font-medium py-2 mb-2 text-center" style="color:<%= lc.text700 %>"><%- loss.formula %></div>
                        <p class="text-xs leading-relaxed" style="color:<%= lc.text700 %>"><%= loss.purpose %></p>
                    </div>
                    <% }) %>
                </div>

                <!-- Hybrid Loss combined formula -->
                <div class="bg-purple-50 border border-purple-200 rounded-xl p-4 mb-8 text-center">
                    <p class="text-xs text-purple-600 font-semibold mb-2">Combined Hybrid Loss</p>
                    <div class="text-purple-800 text-base"><%- hybridLoss.formula %></div>
                    <p class="text-xs text-purple-500 mt-2"><%= hybridLoss.weights %></p>
                </div>

                <!-- Architecture Diagrams -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
                    <div class="rounded-2xl overflow-hidden border border-gray-200 shadow-sm">
                        <img src="assets/asm2_segformer_architecture.png" alt="SegFormer Architecture" class="w-full h-auto" loading="lazy">
                        <p class="text-center text-gray-500 text-sm py-3 bg-gray-50 font-medium">Figure 3a — SegFormer Architecture</p>
                    </div>
                    <div class="rounded-2xl overflow-hidden border border-gray-200 shadow-sm">
                        <img src="assets/asm2_deeplabv3+_architecture.png" alt="DeepLabV3+ Architecture" class="w-full h-auto" loading="lazy">
                        <p class="text-center text-gray-500 text-sm py-3 bg-gray-50 font-medium">Figure 3b — DeepLabV3+ Architecture</p>
                    </div>
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-0 hidden">
                </div>

                <!-- Training Techniques -->
                <h3 class="text-base font-bold text-gray-800 mb-4 flex items-center">
                    <i class="bi bi-gear-fill text-gray-600 mr-2"></i>
                    Advanced Training Techniques
                </h3>
                <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
                    <% trainingTechniques.forEach(function(tech) { -%>
                    <div class="flex items-start bg-gray-50 rounded-xl p-3 border border-gray-200 hover:border-primary-300 transition-colors">
                        <i class="bi <%= tech.icon %> text-primary-500 text-lg mr-3 mt-0.5 flex-shrink-0"></i>
                        <div>
                            <p class="font-semibold text-gray-800 text-xs"><%= tech.name %></p>
                            <p class="text-gray-500 text-xs mt-0.5"><%= tech.description %></p>
                        </div>
                    </div>
                    <% }) -%>
                </div>
            </section>

            <!-- ═══════════════════════════════════════════════════════════ -->
            <!-- REPORT 4 — Experimental Results                           -->
            <!-- ═══════════════════════════════════════════════════════════ -->
            <section id="section-results" class="card scroll-mt-20">
                <div class="flex items-center mb-2">
                    <span class="badge-warning mr-3 text-base px-3 py-1">Report 4</span>
                    <h2 class="text-2xl font-bold text-gray-900">Experimental Results</h2>
                </div>
                <p class="text-gray-500 text-sm mb-8 ml-1">Quantitative tables, training curves, analysis, and discussion on ADE20K validation set</p>

                <!-- Metrics explanation -->
                <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
                    <div class="text-center bg-blue-50 rounded-xl p-4 border border-blue-100">
                        <div class="text-2xl font-bold text-blue-600 mb-1">mIoU</div>
                        <div class="text-xs text-blue-700 font-semibold">Mean IoU</div>
                        <div class="text-xs text-blue-500 mt-1">Average IoU across all 150 classes — primary metric</div>
                    </div>
                    <div class="text-center bg-green-50 rounded-xl p-4 border border-green-100">
                        <div class="text-2xl font-bold text-green-600 mb-1">Dice</div>
                        <div class="text-xs text-green-700 font-semibold">Mean Dice Score</div>
                        <div class="text-xs text-green-500 mt-1">Overlap metric — more sensitive to small objects</div>
                    </div>
                    <div class="text-center bg-purple-50 rounded-xl p-4 border border-purple-100">
                        <div class="text-2xl font-bold text-purple-600 mb-1">PixAcc</div>
                        <div class="text-xs text-purple-700 font-semibold">Pixel Accuracy</div>
                        <div class="text-xs text-purple-500 mt-1">% of correctly classified pixels — skewed by dominant classes</div>
                    </div>
                    <div class="text-center bg-orange-50 rounded-xl p-4 border border-orange-100">
                        <div class="text-2xl font-bold text-orange-600 mb-1">FPS</div>
                        <div class="text-xs text-orange-700 font-semibold">Inference Speed</div>
                        <div class="text-xs text-orange-500 mt-1">Frames per second on GPU at 512×512 resolution</div>
                    </div>
                </div>

                <!-- Comparison Table -->
                <h3 class="text-base font-bold text-gray-800 mb-4 flex items-center">
                    <i class="bi bi-table text-warning-600 mr-2 text-yellow-600"></i>
                    <%= methodologyComparison.description %>
                </h3>
                <div class="overflow-x-auto rounded-xl border border-gray-200 mb-8">
                    <table class="min-w-full divide-y divide-gray-200">
                        <thead class="bg-gray-50">
                            <tr>
                                <% methodologyComparison.columns.forEach(function(column) { -%>
                                <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">
                                    <%= column %>
                                </th>
                                <% }) -%>
                            </tr>
                        </thead>
                        <tbody class="bg-white divide-y divide-gray-200">
                            <% methodologyComparison.rows.forEach(function(row, index) { -%>
                            <tr class="<%= row.highlight ? 'bg-yellow-50 ring-1 ring-yellow-200' : index % 2 === 0 ? 'bg-white' : 'bg-gray-50' %> hover:bg-gray-100 transition-colors">
                                <td class="px-5 py-4 whitespace-nowrap">
                                    <div class="font-semibold text-gray-900 flex items-center gap-2">
                                        <%= row.method %>
                                        <% if (row.highlight) { %><span class="text-xs bg-yellow-100 text-yellow-700 px-1.5 py-0.5 rounded-full font-medium">★ Best</span><% } %>
                                    </div>
                                    <div class="text-xs text-gray-500 mt-0.5"><%= row.description %></div>
                                </td>
                                <td class="px-5 py-4 whitespace-nowrap">
                                    <span class="inline-block text-xs font-medium px-2 py-0.5 rounded-md <%= row.architecture && row.architecture.includes('Transformer') ? 'bg-violet-100 text-violet-700' : 'bg-blue-100 text-blue-700' %>">
                                        <%= row.architecture %>
                                    </span>
                                </td>
                                <td class="px-5 py-4 whitespace-nowrap">
                                    <span class="inline-block text-xs font-medium bg-orange-50 text-orange-700 px-2 py-0.5 rounded-md"><%= row.parameters %></span>
                                </td>
                                <td class="px-5 py-4">
                                    <div class="flex items-center gap-2">
                                        <span class="font-bold text-base <%= row.highlight ? 'text-yellow-600' : 'text-gray-900' %> w-14 flex-shrink-0">
                                            <%= row.accuracy %>
                                        </span>
                                        <div class="flex-1 min-w-16">
                                            <div class="w-full bg-gray-100 rounded-full h-1.5">
                                                <div class="<%= row.highlight ? 'bg-yellow-400' : 'bg-blue-400' %> h-1.5 rounded-full" style="width:<%= parseFloat(row.accuracy) * 100 %>%"></div>
                                            </div>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-5 py-4 whitespace-nowrap text-sm text-gray-700"><%= row.precision %></td>
                                <td class="px-5 py-4 whitespace-nowrap text-sm text-gray-700"><%= row.recall %></td>
                                <td class="px-5 py-4 whitespace-nowrap text-sm text-gray-700"><%= row.valLoss %></td>
                                <td class="px-5 py-4 whitespace-nowrap">
                                    <span class="inline-block text-xs font-medium bg-gray-100 text-gray-600 px-2 py-0.5 rounded-md"><%= row.validClasses %></span>
                                </td>
                            </tr>
                            <% }) -%>
                        </tbody>
                    </table>
                </div>

                <!-- Model Prediction Comparison -->
                <div class="mb-8 rounded-2xl overflow-hidden border border-gray-200 shadow-sm">
                    <img src="assets/asm2_model_prediction_comparison.png" alt="Model Prediction Comparison" class="w-full h-auto" loading="lazy">
                    <p class="text-center text-gray-500 text-sm py-3 bg-gray-50 font-medium">Figure 4 — Model Prediction Comparison</p>
                </div>

                <!-- Analysis & Discussion -->
                <h3 class="text-base font-bold text-gray-800 mb-4 flex items-center">
                    <i class="bi bi-chat-left-text-fill text-gray-500 mr-2"></i>
                    Analysis &amp; Discussion
                </h3>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                    <div class="bg-green-50 rounded-xl p-4 border border-green-200">
                        <h4 class="font-bold text-green-800 text-sm mb-2 flex items-center">
                            <i class="bi bi-trophy-fill text-green-600 mr-2"></i>ConvNeXt-Base — Highest mIoU
                        </h4>
                        <p class="text-green-700 text-xs leading-relaxed">DeepLabV3+ with ConvNeXt-Base backbone achieves the highest mIoU (47.94%) due to 7×7 depthwise convolutions providing a wider receptive field and LayerNorm offering more stable training than BatchNorm on dense scene parsing.</p>
                    </div>
                    <div class="bg-blue-50 rounded-xl p-4 border border-blue-200">
                        <h4 class="font-bold text-blue-800 text-sm mb-2 flex items-center">
                            <i class="bi bi-lightning-fill text-blue-600 mr-2"></i>SegFormer-B2 — Best Efficiency
                        </h4>
                        <p class="text-blue-700 text-xs leading-relaxed">SegFormer-B2 achieves competitive mIoU (46.27%) with only 27.5M parameters — the best FLOPs/mIoU ratio. Global self-attention captures long-range dependencies that ASPP cannot model with fixed dilation rates.</p>
                    </div>
                    <div class="bg-orange-50 rounded-xl p-4 border border-orange-200">
                        <h4 class="font-bold text-orange-800 text-sm mb-2 flex items-center">
                            <i class="bi bi-bar-chart-fill text-orange-600 mr-2"></i>Per-class IoU Analysis
                        </h4>
                        <p class="text-orange-700 text-xs leading-relaxed">Common classes (wall, floor, building) score IoU &gt;60% across all models. Rare classes (microwave, clock, dishwasher) score IoU &lt;20% due to long-tail distribution. Copy-Paste augmentation significantly boosts rare class performance.</p>
                    </div>
                    <div class="bg-purple-50 rounded-xl p-4 border border-purple-200">
                        <h4 class="font-bold text-purple-800 text-sm mb-2 flex items-center">
                            <i class="bi bi-graph-up-arrow text-purple-600 mr-2"></i>Hybrid Loss Impact
                        </h4>
                        <p class="text-purple-700 text-xs leading-relaxed">Hybrid Focal + Dice + Boundary loss outperforms standalone Cross-Entropy by ~2–3% mIoU. Boundary loss is particularly effective for fine-grained structures (windows, furniture legs), producing visibly sharper segmentation edges.</p>
                    </div>
                </div>

                <!-- Per-class IoU -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-8">
                    <div class="rounded-2xl overflow-hidden border border-gray-200 shadow-sm">
                        <img src="assets/asm2_top_20.png" alt="Top 20 Classes by IoU" class="w-full h-auto" loading="lazy">
                        <p class="text-center text-gray-500 text-sm py-3 bg-gray-50 font-medium">Figure 5a — Top 20 Classes by IoU</p>
                    </div>
                    <div class="rounded-2xl overflow-hidden border border-gray-200 shadow-sm">
                        <img src="assets/asm2_bottom_20.png" alt="Bottom 20 Classes by IoU" class="w-full h-auto" loading="lazy">
                        <p class="text-center text-gray-500 text-sm py-3 bg-gray-50 font-medium">Figure 5b — Bottom 20 Classes by IoU</p>
                    </div>
                </div>
            </section>

            <!-- ═══════════════════════════════════════════════════════════ -->
            <!-- REPORT 5 — Extension: Interpretability & Benchmarking     -->
            <!-- ═══════════════════════════════════════════════════════════ -->
            <section id="section-extension" class="card scroll-mt-20">
                <div class="flex items-center mb-2">
                    <span class="badge-danger mr-3 text-base px-3 py-1">Report 5</span>
                    <h2 class="text-2xl font-bold text-gray-900">Extension Reports</h2>
                </div>
                <p class="text-gray-500 text-sm mb-8 ml-1">Model Interpretability (Attention Maps / Grad-CAM) and Efficiency Benchmarking (FPS / FLOPs / Memory)</p>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mb-8">
                    <% interpretability.forEach(function(item) { var ic = cm(item.color); -%>
                    <div class="bg-white rounded-xl p-4 hover:shadow-md transition-shadow border" style="border-color:<%= ic.border %>">
                        <div class="flex items-center mb-3">
                            <div class="w-8 h-8 rounded-lg flex items-center justify-center mr-3" style="background-color:<%= ic.bg100 %>">
                                <i class="bi <%= item.icon %>" style="color:<%= ic.text600 %>"></i>
                            </div>
                            <div>
                                <p class="font-bold text-gray-900 text-sm"><%= item.model %></p>
                                <span class="text-xs px-2 py-0.5 rounded-full" style="background-color:<%= ic.bg100 %>;color:<%= ic.text700 %>"><%= item.technique %></span>
                            </div>
                        </div>
                        <p class="text-gray-600 text-xs leading-relaxed"><%= item.shows %></p>
                    </div>
                    <% }) %>
                </div>

                <!-- Interpretability -->
                <h3 class="text-base font-bold text-gray-800 mb-5 flex items-center">
                    <i class="bi bi-eye-fill text-red-500 mr-2"></i>
                    Section 9 — Model Interpretability: Attention Maps &amp; Grad-CAM
                </h3>
                <div class="space-y-6 mb-8">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="rounded-2xl overflow-hidden border border-gray-200 shadow-sm">
                            <img src="assets/asm2_segformer_attention_feature_map.png" alt="SegFormer Attention Feature Maps 1" class="w-full h-auto" loading="lazy">
                            <p class="text-center text-gray-500 text-sm py-3 bg-gray-50 font-medium">Figure 6a — SegFormer Attention Maps (1)</p>
                        </div>
                        <div class="rounded-2xl overflow-hidden border border-gray-200 shadow-sm">
                            <img src="assets/asm2_segformer_attention_feature_map_2.png" alt="SegFormer Attention Feature Maps 2" class="w-full h-auto" loading="lazy">
                            <p class="text-center text-gray-500 text-sm py-3 bg-gray-50 font-medium">Figure 6b — SegFormer Attention Maps (2)</p>
                        </div>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="rounded-2xl overflow-hidden border border-gray-200 shadow-sm">
                            <img src="assets/asm2_deeplabv3+_resnet_gradCAM.png" alt="DeepLabV3+ ResNet Grad-CAM" class="w-full h-auto" loading="lazy">
                            <p class="text-center text-gray-500 text-sm py-3 bg-gray-50 font-medium">Figure 6c — DeepLabV3+ ResNet-101 Grad-CAM</p>
                        </div>
                        <div class="rounded-2xl overflow-hidden border border-gray-200 shadow-sm">
                            <img src="assets/asm2_deeplabv3+_convnext_gradCAM.png" alt="DeepLabV3+ ConvNeXt Grad-CAM" class="w-full h-auto" loading="lazy">
                            <p class="text-center text-gray-500 text-sm py-3 bg-gray-50 font-medium">Figure 6d — DeepLabV3+ ConvNeXt-Base Grad-CAM</p>
                        </div>
                    </div>
                </div>

                <!-- Key interpretability insight -->
                <div class="bg-gray-900 text-gray-100 rounded-2xl p-5 mb-8 text-sm">
                    <h4 class="font-bold text-white mb-3 flex items-center">
                        <i class="bi bi-lightbulb-fill text-yellow-400 mr-2"></i>
                        Key Interpretability Observations
                    </h4>
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 text-xs leading-relaxed">
                        <div>
                            <p class="text-yellow-400 font-semibold mb-1">SegFormer Attention</p>
                            <p class="text-gray-300">Shows global context aggregation — later encoder stages (Stage 3, 4) attend to larger structural regions (room, wall) while early stages focus on local textures.</p>
                        </div>
                        <div>
                            <p class="text-green-400 font-semibold mb-1">ResNet Grad-CAM</p>
                            <p class="text-gray-300">Highlights local discriminative features — edges, textures, and high-frequency patterns near object boundaries. Sharper but narrower focus than SegFormer.</p>
                        </div>
                        <div>
                            <p class="text-blue-400 font-semibold mb-1">ConvNeXt Grad-CAM</p>
                            <p class="text-gray-300">Broader contextual regions due to 7×7 depthwise conv. Captures more semantic context per activation, explaining its higher mIoU on complex scenes.</p>
                        </div>
                    </div>
                </div>

                <!-- Benchmarking -->
                <h3 class="text-base font-bold text-gray-800 mb-5 flex items-center">
                    <i class="bi bi-speedometer2 text-red-500 mr-2"></i>
                    Section 10 — Benchmarking: FPS, Parameters &amp; FLOPs
                </h3>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-6">
                    <% architectures.forEach(function(arch) { -%>
                    <div class="rounded-2xl border border-gray-200 p-5 bg-white hover:shadow-md transition-shadow">
                        <div class="flex items-center justify-between mb-4">
                            <h4 class="font-bold text-gray-900 text-sm"><%= arch.name %></h4>
                            <% if (arch.highlight) { -%>
                            <span class="text-xs bg-yellow-100 text-yellow-700 px-2 py-0.5 rounded-full">Best mIoU</span>
                            <% } -%>
                        </div>
                        <div class="space-y-3">
                            <div>
                                <div class="flex justify-between text-xs mb-1">
                                    <span class="text-gray-500">mIoU</span>
                                    <span class="font-bold" style="color: <%= arch.color === 'primary' ? '#3b82f6' : arch.color === 'success' ? '#22c55e' : '#06b6d4' %>"><%= arch.miou %>%</span>
                                </div>
                                <div class="w-full bg-gray-100 rounded-full h-1.5">
                                    <div class="h-1.5 rounded-full" style="width: <%= arch.miou %>%; background-color: <%= arch.color === 'primary' ? '#3b82f6' : arch.color === 'success' ? '#22c55e' : '#06b6d4' %>"></div>
                                </div>
                            </div>
                            <div>
                                <div class="flex justify-between text-xs mb-1">
                                    <span class="text-gray-500">Parameters</span>
                                    <span class="font-semibold text-gray-700"><%= arch.params %></span>
                                </div>
                            </div>
                            <div class="pt-2 border-t border-gray-100">
                                <p class="text-xs text-gray-500 font-semibold mb-1">Tradeoff Summary</p>
                                <p class="text-xs text-gray-600 leading-relaxed">
                                    <% if (arch.name === 'SegFormer-B2') { %>Best FLOPs/mIoU ratio, most deployment-friendly.<% } else if (arch.name === 'DeepLabV3+ ResNet-101') { %>Solid baseline, proven architecture on scene understanding.<% } else { %>Highest accuracy at cost of speed and memory (89.4M params).<% } %>
                                </p>
                            </div>
                        </div>
                    </div>
                    <% }) -%>
                </div>

                <!-- Pareto note -->
                <div class="bg-red-50 border border-red-200 rounded-xl p-4">
                    <div class="flex items-start">
                        <i class="bi bi-graph-up text-red-500 mr-3 mt-0.5 text-lg"></i>
                        <div>
                            <p class="font-bold text-red-800 text-sm mb-1">Pareto Analysis — Efficiency vs Accuracy</p>
                            <p class="text-red-700 text-xs leading-relaxed">
                                FPS vs. mIoU scatter plot (bubble size = #params) shows: <strong>SegFormer-B2 lies on the Pareto frontier</strong> — high accuracy with the fewest parameters and fastest inference speed. ConvNeXt achieves higher accuracy but is not Pareto-optimal due to large compute cost. DeepLabV3+ ResNet-101 falls below the Pareto frontier → suboptimal in both dimensions.
                            </p>
                        </div>
                    </div>
                </div>
            </section>

            <!-- ═══════════════════════════════════════════════════════════ -->
            <!-- Reports Navigation Overview                               -->
            <!-- ═══════════════════════════════════════════════════════════ -->
            <section class="card">
                <div class="flex items-center mb-6">
                    <i class="bi bi-folder-fill text-2xl text-green-600 mr-3"></i>
                    <h2 class="text-2xl font-bold text-gray-900">Report Overview</h2>
                </div>                
                <div class="space-y-4">
                    <% reports.forEach(function(report) { -%>
                    <div class="card-flat group hover:border-<%= report.color === 'danger' ? 'red' : report.color %>-300 border-l-4 border-<%= report.color === 'danger' ? 'red' : report.color %>-500 transition-all duration-300 hover:translate-x-1">
                        <div class="flex flex-col md:flex-row md:items-center justify-between">
                            <div class="mb-4 md:mb-0 md:mr-6">
                                <div class="flex items-center mb-3">
                                    <span class="badge-<%= report.color %> mr-3">
                                        <%= report.number %>
                                    </span>
                                    <h3 class="text-lg font-semibold text-gray-900"><%= report.title %></h3>
                                </div>
                                <p class="text-gray-700 font-medium mb-3 text-sm"><%= report.subtitle %></p>
                                <ul class="space-y-1">
                                    <% report.items.forEach(function(item) { -%>
                                    <li class="flex items-start text-gray-600 text-sm">
                                        <i class="bi bi-dot text-lg mr-1 mt-0.5"></i>
                                        <span><%= item %></span>
                                    </li>
                                    <% }) -%>
                                </ul>
                            </div>
                            <a href="<%= report.link %>" 
                               class="btn-<%= report.color === 'danger' ? 'outline border-red-300 text-red-600 hover:bg-red-50' : report.color %> inline-flex items-center self-start md:self-center whitespace-nowrap text-sm">
                                <i class="bi bi-arrow-up-right mr-2"></i>View Details
                            </a>
                        </div>
                    </div>
                    <% }) -%>
                </div>
            </section>
            
            <!-- Navigation -->
            <div class="flex flex-col sm:flex-row justify-between items-center gap-4 pt-8 border-t border-gray-200">
                <a href="assignment1.html" class="btn-outline inline-flex items-center">
                    <i class="bi bi-arrow-left mr-2"></i>
                    Back to Assignment 1
                </a>
                <a href="index.html" class="btn-primary inline-flex items-center">
                    Return to Home
                    <i class="bi bi-house-door ml-2"></i>
                </a>
            </div>
        </div>
    </main>
    
    <!-- Footer -->
    <%- component('organisms/Footer/Footer', {
        site: site,
        group: group,
        instructor: instructor,
        assignment: assignment
    }) -%>
    
    <!-- Scripts -->
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            document.body.classList.add('page-loaded');
            // Smooth-scroll anchor highlighting
            const sections = document.querySelectorAll('section[id]');
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(e => {
                    if (e.isIntersecting) {
                        document.querySelectorAll('a[href^="#section-"]').forEach(a => {
                            a.classList.toggle('font-bold', a.getAttribute('href') === '#' + e.target.id);
                        });
                    }
                });
            }, { threshold: 0.3 });
            sections.forEach(s => observer.observe(s));
        });
    </script>
</body>
</html>