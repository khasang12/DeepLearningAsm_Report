<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<%- component('organisms/Head/Head', {
    title: site.title + ' - Group ' + group.name,
    description: site.description,
    author: group.name,
    group: group
}) -%>
<body class="min-h-screen bg-gray-50 text-gray-900 font-sans antialiased page-loading dark:bg-gray-900 dark:text-gray-100">
    
    <!-- Header -->
    <%- component('organisms/Header/Header', {
        title: site.title,
        subtitle: site.course + ' - Academic Year ' + site.academicYear,
        gradient: gradient || 'gradient-home',
        showHomeButton: false,
        showAssignmentInfo: false,
        group: group,
        instructor: instructor
    }) -%>
    
    <!-- Main Content -->
    <main class="container mx-auto px-4 py-8 md:py-12">
        <div class="max-w-7xl mx-auto">            
            <!-- Assignments Navigation -->
            <div class="mb-12">
                <div class="flex items-center mb-8">
                    <i class="bi bi-link-45deg text-2xl text-primary-600 mr-3"></i>
                    <h2 class="text-2xl font-bold text-gray-900">Assignments Navigation</h2>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

                    <!-- ── Assignment 1 Card ── -->
                    <div class="card group hover:border-primary-200 hover:shadow-lg transition-all duration-300 flex flex-col">

                        <!-- Header -->
                        <div class="flex items-start justify-between mb-4">
                            <div class="flex items-center gap-3">
                                <div class="inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-primary-100 text-primary-600 group-hover:bg-primary-200 transition-colors flex-shrink-0">
                                    <i class="bi bi-cpu-fill text-2xl"></i>
                                </div>
                                <div>
                                    <h3 class="text-xl font-bold text-gray-900 leading-tight">Assignment 1</h3>
                                    <span class="inline-block bg-primary-100 text-primary-700 text-xs font-semibold px-2.5 py-0.5 rounded-full mt-1">Image Classification</span>
                                </div>
                            </div>
                            <span class="flex-shrink-0 bg-green-100 text-green-700 text-xs font-bold px-2.5 py-1 rounded-full flex items-center gap-1">
                                <i class="bi bi-check-circle-fill text-xs"></i> Complete
                            </span>
                        </div>

                        <!-- Description -->
                        <p class="text-gray-600 text-sm mb-4 leading-relaxed">
                            Multi-modal image classification exploring CNN-based architectures on CIFAR-100, custom Image, Text, and Multimodal datasets.
                        </p>

                        <!-- Tech Stack Badges -->
                        <div class="flex flex-wrap gap-1.5 mb-5">
                            <span class="bg-blue-50 text-blue-700 border border-blue-200 text-xs px-2 py-0.5 rounded-md font-medium">PyTorch</span>
                            <span class="bg-orange-50 text-orange-700 border border-orange-200 text-xs px-2 py-0.5 rounded-md font-medium">ResNet</span>
                            <span class="bg-purple-50 text-purple-700 border border-purple-200 text-xs px-2 py-0.5 rounded-md font-medium">BERT</span>
                            <span class="bg-green-50 text-green-700 border border-green-200 text-xs px-2 py-0.5 rounded-md font-medium">BiLSTM</span>
                            <span class="bg-pink-50 text-pink-700 border border-pink-200 text-xs px-2 py-0.5 rounded-md font-medium">CLIP</span>
                        </div>

                        <!-- Key Stats -->
                        <div class="grid grid-cols-3 gap-3 mb-5">
                            <div class="bg-gray-50 rounded-xl p-3 text-center border border-gray-100">
                                <div class="text-lg font-bold text-primary-600">5</div>
                                <div class="text-xs text-gray-500 mt-0.5">Models</div>
                            </div>
                            <div class="bg-gray-50 rounded-xl p-3 text-center border border-gray-100">
                                <div class="text-lg font-bold text-green-600">3</div>
                                <div class="text-xs text-gray-500 mt-0.5">Datasets</div>
                            </div>
                            <div class="bg-gray-50 rounded-xl p-3 text-center border border-gray-100">
                                <div class="text-lg font-bold text-orange-600">100</div>
                                <div class="text-xs text-gray-500 mt-0.5">Classes</div>
                            </div>
                        </div>

                        <!-- Progress -->
                        <div class="mb-5">
                            <div class="flex justify-between text-xs text-gray-500 mb-1.5">
                                <span class="font-medium">Report Progress</span>
                                <span class="font-bold text-primary-600">100%</span>
                            </div>
                            <div class="w-full bg-gray-100 rounded-full h-2">
                                <div class="bg-gradient-to-r from-primary-500 to-primary-400 h-2 rounded-full transition-all duration-1000" style="width: 100%"></div>
                            </div>
                        </div>

                        <!-- CTA -->
                        <div class="mt-auto">
                            <a href="<%= navigation.assignment1 %>"
                               class="btn-primary w-full inline-flex items-center justify-center gap-2">
                                <i class="bi bi-folder2-open"></i>
                                View Assignment 1
                                <i class="bi bi-arrow-right ml-auto"></i>
                            </a>
                        </div>
                    </div>

                    <!-- ── Assignment 2 Card ── -->
                    <div class="card group hover:border-purple-200 hover:shadow-lg transition-all duration-300 flex flex-col">

                        <!-- Header -->
                        <div class="flex items-start justify-between mb-4">
                            <div class="flex items-center gap-3">
                                <div class="inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-purple-100 text-purple-600 group-hover:bg-purple-200 transition-colors flex-shrink-0">
                                    <i class="bi bi-grid-3x3-gap-fill text-2xl"></i>
                                </div>
                                <div>
                                    <h3 class="text-xl font-bold text-gray-900 leading-tight">Assignment 2</h3>
                                    <span class="inline-block bg-purple-100 text-purple-700 text-xs font-semibold px-2.5 py-0.5 rounded-full mt-1">Semantic Segmentation</span>
                                </div>
                            </div>
                            <span class="flex-shrink-0 bg-yellow-100 text-yellow-700 text-xs font-bold px-2.5 py-1 rounded-full flex items-center gap-1">
                                <i class="bi bi-hourglass-split text-xs"></i> In Progress
                            </span>
                        </div>

                        <!-- Description -->
                        <p class="text-gray-600 text-sm mb-4 leading-relaxed">
                            ADE20K scene parsing with Transformer and CNN-based architectures, featuring hybrid loss functions and advanced augmentation strategies.
                        </p>

                        <!-- Tech Stack Badges -->
                        <div class="flex flex-wrap gap-1.5 mb-5">
                            <span class="bg-blue-50 text-blue-700 border border-blue-200 text-xs px-2 py-0.5 rounded-md font-medium">PyTorch</span>
                            <span class="bg-violet-50 text-violet-700 border border-violet-200 text-xs px-2 py-0.5 rounded-md font-medium">SegFormer</span>
                            <span class="bg-green-50 text-green-700 border border-green-200 text-xs px-2 py-0.5 rounded-md font-medium">DeepLabV3+</span>
                            <span class="bg-sky-50 text-sky-700 border border-sky-200 text-xs px-2 py-0.5 rounded-md font-medium">ConvNeXt</span>
                            <span class="bg-rose-50 text-rose-700 border border-rose-200 text-xs px-2 py-0.5 rounded-md font-medium">ADE20K</span>
                        </div>

                        <!-- Key Stats -->
                        <div class="grid grid-cols-3 gap-3 mb-5">
                            <div class="bg-gray-50 rounded-xl p-3 text-center border border-gray-100">
                                <div class="text-lg font-bold text-purple-600">3</div>
                                <div class="text-xs text-gray-500 mt-0.5">Models</div>
                            </div>
                            <div class="bg-gray-50 rounded-xl p-3 text-center border border-gray-100">
                                <div class="text-lg font-bold text-green-600">150</div>
                                <div class="text-xs text-gray-500 mt-0.5">Classes</div>
                            </div>
                            <div class="bg-gray-50 rounded-xl p-3 text-center border border-gray-100">
                                <div class="text-lg font-bold text-orange-600">48.5%</div>
                                <div class="text-xs text-gray-500 mt-0.5">Best mIoU</div>
                            </div>
                        </div>

                        <!-- Progress -->
                        <div class="mb-5">
                            <div class="flex justify-between text-xs text-gray-500 mb-1.5">
                                <span class="font-medium">Report Progress</span>
                                <span class="font-bold text-purple-600">100%</span>
                            </div>
                            <div class="w-full bg-gray-100 rounded-full h-2">
                                <div class="bg-gradient-to-r from-purple-500 to-purple-400 h-2 rounded-full transition-all duration-1000" style="width: 100%"></div>
                            </div>
                            <div class="flex gap-3 mt-2">
                                <span class="flex items-center gap-1 text-xs text-green-600"><i class="bi bi-check-circle-fill text-xs"></i>EDA</span>
                                <span class="flex items-center gap-1 text-xs text-green-600"><i class="bi bi-check-circle-fill text-xs"></i>Data Pipeline</span>
                                <span class="flex items-center gap-1 text-xs text-green-600"><i class="bi bi-check-circle-fill text-xs"></i>Methods</span>
                                <span class="flex items-center gap-1 text-xs text-green-600"><i class="bi bi-check-circle-fill text-xs"></i>Results</span>
                            </div>
                        </div>

                        <!-- CTA -->
                        <div class="mt-auto">
                            <a href="<%= navigation.assignment2 %>"
                               class="w-full inline-flex items-center justify-center gap-2 btn-primary bg-purple-600 hover:bg-purple-700 focus:ring-purple-500">
                                <i class="bi bi-folder2-open"></i>
                                View Assignment 2
                                <i class="bi bi-arrow-right ml-auto"></i>
                            </a>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </main>

    
    <!-- Footer -->
    <%- component('organisms/Footer/Footer', {
        site: site,
        group: group,
        instructor: instructor
    }) -%>
    
    <!-- Scripts -->
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            document.body.classList.add('page-loaded');
        });
    </script>
</body>
</html>