{
  "name": "deep-learning-assignments",
  "version": "1.0.0",
  "description": "GitHub Pages for Deep Learning assignments with Atomic Design",
  "main": "build.js",
  "scripts": {
    "dev": "concurrently \"npm run build:watch\" \"npm run serve\"",
    "build": "npm-run-all build:clean build:pages build:css build:copy",
    "build:clean": "rm -rf dist && mkdir -p dist",
    "build:pages": "node build.js --pages",
    "build:css": "npx postcss src/styles/input.css -o dist/styles.css --env production",
    "build:css:dev": "npx postcss src/styles/input.css -o dist/styles.css",
    "build:copy": "mkdir -p dist/data && cp -r src/assets dist/ && cp src/data/*.ipynb dist/data/ 2>/dev/null || true && cp _config.yml .nojekyll dist/",
    "build:watch": "npx nodemon --legacy-watch --watch src -e ejs,json,css --exec npm run build:pages",
    "serve": "npx live-server dist --port=3000 --watch=dist",
    "preview": "npm run build && npx live-server dist --port=3000"
  },
  "keywords": [
    "deep-learning",
    "github-pages",
    "tailwindcss",
    "atomic-design"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.10",
    "autoprefixer": "^10.4.19",
    "chokidar-cli": "^3.0.0",
    "concurrently": "^8.2.2",
    "ejs": "^3.1.9",
    "live-server": "^1.2.0",
    "nodemon": "^3.1.0",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.4.38",
    "postcss-cli": "^11.0.1",
    "tailwindcss": "^3.4.0"
  }
}
